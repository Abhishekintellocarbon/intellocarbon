NEXT_PUBLIC_API_URL=http://localhost:4000

# Error monitoring (Sentry) — leave blank to disable (Sentry.init() becomes a
# no-op client). NEXT_PUBLIC_ prefix is required so the client bundle can
# read it; this is fine since Sentry DSNs aren't secret. Get a DSN by
# creating a Next.js project at https://sentry.io.
NEXT_PUBLIC_SENTRY_DSN_FRONTEND=

# Only needed to upload source maps at build time (readable prod stack
# traces in Sentry) — safe to leave blank, the build just skips the upload.
# Found in Sentry under Settings > Auth Tokens (needs project:releases scope).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
