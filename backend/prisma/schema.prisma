generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime connection — in production (Supabase) this is the pooled/PgBouncer
  // connection string (port 6543, ?pgbouncer=true).
  url       = env("DATABASE_URL")
  // Used only by `prisma migrate` / `prisma db push` — must be a direct,
  // non-pooled connection (port 5432). Locally this is the same as DATABASE_URL.
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  MEMBER
  VERIFIER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id               String         @id @default(cuid())
  name             String
  email            String         @unique
  passwordHash     String
  companyName      String?
  role             Role           @default(ADMIN)
  // Gates dashboard/API access — set on signup, flipped by a super admin from
  // the Pending Approvals panel. Existing pre-feature accounts were backfilled
  // to APPROVED (see migration), so this only blocks new signups.
  approvalStatus   ApprovalStatus @default(PENDING)
  emailVerified    Boolean        @default(false)
  failedLoginCount Int            @default(0)
  lockedUntil      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  refreshTokens            RefreshToken[]
  passwordResetTokens      PasswordResetToken[]
  company                  Company?
  verificationsHandled     VerificationRequest[]     @relation("VerifierAssignments")
  brsrVerificationsHandled BrsrVerificationRequest[] @relation("BrsrVerifierAssignments")
  notifications            Notification[]
  auditLogs                AuditLog[]

  @@map("users")
}

enum Sector {
  STEEL
  CEMENT
  ALUMINIUM
  FERTILIZER
  HYDROGEN
  ELECTRICITY
  OTHER
}

model Company {
  id                      String    @id @default(cuid())
  ownerId                 String    @unique
  owner                   User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name                    String
  registrationNumber      String?
  sector                  Sector
  subSector               String?
  address                 String?
  city                    String?
  state                   String?
  pincode                 String?
  country                 String    @default("India")
  annualTurnoverInr       Float?
  employeeCount           Int?
  reportingFyStartMonth   Int       @default(4)
  appliesCbam             Boolean   @default(false)
  appliesCcts             Boolean   @default(false)
  isPatDesignatedConsumer Boolean   @default(false)
  onboardingCompletedAt   DateTime?

  // EU declarant / importer of record — CBAM report page 4
  euImporterName         String?
  euImporterEori         String?
  euImporterCountry      String?
  euImporterContactEmail String?
  euImporterContactPhone String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  facilities           Facility[]
  // A company can hold more than one active tier at once (e.g. CBAM +
  // BRSR_CORE_REPORTING bought separately) — see [[companyId, tier]] below.
  // Was a 1:1 `Subscription?` until BRSR Core needed to be purchasable as a
  // standalone add-on alongside an existing CBAM/CCTS plan rather than only
  // as a pre-bundled combo tier like CBAM_PLUS_CCTS.
  subscriptions        Subscription[]
  verificationRequests VerificationRequest[]
  notifications        Notification[]
  brsrCoreReports      BrsrCoreReport[]
  auditLogs            AuditLog[]
  reports              Report[]
  documents            Document[]

  @@map("companies")
}

enum SubscriptionTier {
  CCTS_COMPLIANCE
  CBAM_COMPLIANCE
  CBAM_PLUS_CCTS
  BRSR_CORE_REPORTING
}

enum SubscriptionStatus {
  INCOMPLETE
  ACTIVE
  PAST_DUE
  CANCELED
}

model Subscription {
  id                     String             @id @default(cuid())
  companyId              String
  company                Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tier                   SubscriptionTier   @default(CCTS_COMPLIANCE)
  status                 SubscriptionStatus @default(INCOMPLETE)
  razorpayCustomerId     String?
  razorpaySubscriptionId String?            @unique
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  payments Payment[]

  // One subscription row per (company, tier) — a company can hold several
  // tiers simultaneously (each its own Razorpay subscription), but can't
  // double-purchase the same tier twice.
  @@unique([companyId, tier])
  @@index([companyId])
  @@map("subscriptions")
}

model Payment {
  id                String       @id @default(cuid())
  subscriptionId    String
  subscription      Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  razorpayPaymentId String?      @unique
  razorpayOrderId   String?
  amountInr         Float
  status            String
  paidAt            DateTime?
  createdAt         DateTime     @default(now())

  @@index([subscriptionId])
  @@map("payments")
}

enum VerificationStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
}

model VerificationRequest {
  id                  String             @id @default(cuid())
  activityDataId      String             @unique
  activityData        ActivityData       @relation(fields: [activityDataId], references: [id], onDelete: Cascade)
  companyId           String
  company             Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  status              VerificationStatus @default(PENDING)
  verifierId          String?
  verifier            User?              @relation("VerifierAssignments", fields: [verifierId], references: [id])
  verifierOrg         String?
  accreditationNumber String?
  statement           String?
  comments            String?
  submittedAt         DateTime           @default(now())
  decidedAt           DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([companyId])
  @@index([verifierId])
  @@map("verification_requests")
}

enum NotificationType {
  MONTHLY_REMINDER
  DEADLINE_WARNING_30D
  DEADLINE_URGENT_7D
}

model Notification {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // Set for facility-specific alerts (monthly reminder); null for
  // company-wide deadline alerts (which aren't about any one facility).
  facilityId  String?
  facility    Facility?        @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  type        NotificationType
  title       String
  body        String
  // Uniquely identifies "this alert, for this company, for this period" —
  // e.g. "monthly:<facilityId>:2026-07", "cbam-30d:2026-Q3", "ccts-7d:2026".
  // Lets the daily cron run unconditionally every day and rely on the
  // unique constraint below to silently no-op on days 2..N of a window,
  // instead of tracking "have I already sent this" separately. Encoding the
  // facility id inside the string (rather than making facilityId part of
  // the constraint) sidesteps Postgres treating NULL as distinct-from-NULL,
  // which would otherwise break dedup for the facility-less company-wide
  // alerts.
  dedupeKey   String
  readAt      DateTime?
  emailSentAt DateTime?
  createdAt   DateTime         @default(now())

  @@unique([companyId, dedupeKey])
  @@index([userId])
  @@map("notifications")
}

enum AuditLogAction {
  REPORT_GENERATED
}

// Minimal append-only event log for the per-facility "Recent Activity" feed
// (see facilityDashboard.service.ts) and the Super Admin overview's
// platform-wide activity feed. Only covers actions with no other timestamped
// record to source from — data submissions, verifier claims/decisions, and
// deadline alerts are read directly off ActivityData, VerificationRequest,
// and Notification instead of being duplicated here.
model AuditLog {
  id         String          @id @default(cuid())
  facilityId String
  facility   Facility        @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  companyId  String
  company    Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // Who triggered the action — nullable since not every future action type
  // will necessarily have one (e.g. a system/cron-triggered event).
  userId     String?
  user       User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     AuditLogAction
  detail     String
  createdAt  DateTime        @default(now())

  @@index([facilityId])
  @@map("audit_logs")
}

enum ReportType {
  CBAM
  CCTS
  BRSR
}

enum ReportStatus {
  GENERATED
}

// One row per (facility, reportType, period) — the record of a generated
// compliance report, from the dashboard's "Generate Report" flow. `pdfPath`
// is a stable human-readable reference (used for the download filename),
// not an on-disk path — the actual PDF bytes live on the linked Document
// row, since Render's filesystem is ephemeral and can't be used as durable
// storage.
model Report {
  id          String       @id @default(cuid())
  facilityId  String
  facility    Facility     @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  companyId   String
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reportType  ReportType
  period      String
  generatedAt DateTime     @default(now())
  pdfPath     String
  status      ReportStatus @default(GENERATED)

  document Document?

  @@unique([facilityId, reportType, period])
  @@index([facilityId])
  @@map("reports")
}

enum DocumentType {
  REPORT
  // User-uploaded bills/invoices backing a specific activity_data submission
  // — see ActivityData.documents and the "Evidence Pending" flag it drives.
  SUPPORTING_EVIDENCE
}

// Either the generated PDF for a Report, or a user-uploaded supporting
// document for an ActivityData submission — exactly one of reportId /
// activityDataId is set, matching documentType. Both stored in Postgres
// (not on disk) since Render's filesystem is ephemeral; this is a separate
// table from Report so a future third document type can reuse it without a
// migration, and so list views never have to pull file bytes they don't need.
model Document {
  id              String        @id @default(cuid())
  facilityId      String
  facility        Facility      @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reportId        String?       @unique
  report          Report?       @relation(fields: [reportId], references: [id], onDelete: Cascade)
  activityDataId  String?
  activityData    ActivityData? @relation(fields: [activityDataId], references: [id], onDelete: Cascade)
  documentType    DocumentType  @default(REPORT)
  reportingPeriod String
  verified        Boolean       @default(false)
  fileName        String
  fileData        Bytes
  createdAt       DateTime      @default(now())

  @@index([facilityId])
  @@index([activityDataId])
  @@map("documents")
}

enum FacilityType {
  INTEGRATED_STEEL_PLANT
  EAF_MINI_MILL
  DRI_PLANT
  ROLLING_MILL
  PELLET_PLANT
  CEMENT_PLANT
  ALUMINIUM_SMELTER
  FERTILIZER_PLANT
  HYDROGEN_PLANT
  POWER_PLANT
  OTHER
}

enum HydrogenRoute {
  SMR
  SMR_CCS
  ELECTROLYSIS_GRID
  ELECTROLYSIS_RENEWABLE
  BIOMASS
}

model Facility {
  id                   String        @id @default(cuid())
  companyId            String
  company              Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name                 String
  // Nullable to support autosaved drafts, which may not have these set yet —
  // both are required by app-layer validation before isDraft can flip false.
  facilityType         FacilityType?
  // Free-text production-route key (e.g. "BF_BOF", "CLINKER_PRODUCTION",
  // "HALL_HEROULT") validated app-side against a per-sector option list —
  // not a Prisma enum, since each new CBAM sector adds its own route set and
  // a shared enum would need a migration every time one changes.
  productionRoute      String?
  address              String?
  state                String?
  district             String?
  pincode              String?
  latitude             Float?
  longitude            Float?
  installedCapacityTpa Float?
  commissioningYear    Int?
  productsManufactured String[]
  cnCodes              String[]      @default([])
  // True until the user explicitly clicks "Mark as complete" — autosave
  // never sets this to false. Incomplete facilities are still visible (with
  // a Draft badge) but should be treated as not-yet-real by anything that
  // isn't the setup form itself.
  isDraft              Boolean       @default(true)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  activityData    ActivityData[]
  notifications   Notification[]
  brsrCoreReports BrsrCoreReport[]
  auditLogs       AuditLog[]
  reports         Report[]
  documents       Document[]

  @@index([companyId])
  @@map("facilities")
}

enum DataEntryStatus {
  DRAFT
  SUBMITTED
}

model ActivityData {
  id                  String    @id @default(cuid())
  facilityId          String
  facility            Facility  @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  // Denormalised from the owning Company at creation time — lets the
  // calculation engine and reports branch per sector without an extra join.
  sector              Sector    @default(STEEL)
  // Nullable to support autosaved drafts — all four are required by
  // app-layer validation before status can flip to SUBMITTED.
  periodStart         DateTime?
  periodEnd           DateTime?
  productCategory     String?
  productionQuantityT Float?

  gridElectricityMwh         Float  @default(0)
  renewableElectricityMwh    Float  @default(0)
  gridEmissionFactorOverride Float?

  steamImportedGj             Float  @default(0)
  steamEmissionFactorOverride Float?

  // --- Cement (calcination) ---
  limestoneInputTonnes      Float?
  clinkerProducedTonnes     Float?
  clinkerConversionFraction Float?

  // --- Aluminium (PFC — perfluorocarbons from anode effects) ---
  cf4EmissionsTonnes  Float?
  c2f6EmissionsTonnes Float?
  anodeEffectMinutes  Float?

  // --- Fertilizer (N2O from nitric acid production + gas feedstock carbon) ---
  n2oProcessEmissionsTonnes Float?
  n2oAbatementFactorPct     Float?
  naturalGasFeedstockNm3    Float?

  // --- Hydrogen ---
  hydrogenRoute         HydrogenRoute?
  ccsCaptureRatePct     Float?
  hydrogenPurityPct     Float?
  byproductOxygenTonnes Float?

  // --- Electricity (CBAM SEE is per MWh exported to the EU, not per tonne) ---
  electricityGeneratedMwh  Float?
  electricityExportedEuMwh Float?
  ownUseElectricityMwh     Float?
  lineLossMwh              Float?

  // CBAM Article 9 deduction input — carbon price effectively paid in the
  // country of origin, expressed directly in EUR/tCO2e.
  carbonPricePaidEurPerTonne Float?
  // BEE-notified CCTS GHG emission intensity target for this sub-sector/cycle,
  // tCO2e per tonne product — left null until BEE actually notifies one.
  cctsTargetIntensity        Float?

  status DataEntryStatus @default(DRAFT)
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fuelEntries            FuelEntry[]
  processMaterialEntries ProcessMaterialEntry[]
  precursorEntries       PrecursorEntry[]
  calculationResult      EmissionCalculationResult?
  verificationRequest    VerificationRequest?
  // Supporting evidence (bills/invoices) backing this submission — an empty
  // list on a SUBMITTED entry is what "Evidence Pending" means; computed on
  // read, not stored, so it can never go stale.
  documents              Document[]

  @@index([facilityId])
  @@map("activity_data")
}

model FuelEntry {
  id                        String       @id @default(cuid())
  activityDataId            String
  activityData              ActivityData @relation(fields: [activityDataId], references: [id], onDelete: Cascade)
  fuelType                  String
  quantity                  Float
  unit                      String
  emissionFactorOverrideCo2 Float?
  createdAt                 DateTime     @default(now())

  @@index([activityDataId])
  @@map("fuel_entries")
}

model ProcessMaterialEntry {
  id                     String       @id @default(cuid())
  activityDataId         String
  activityData           ActivityData @relation(fields: [activityDataId], references: [id], onDelete: Cascade)
  materialType           String
  quantityTonnes         Float
  emissionFactorOverride Float?
  createdAt              DateTime     @default(now())

  @@index([activityDataId])
  @@map("process_material_entries")
}

model PrecursorEntry {
  id                             String       @id @default(cuid())
  activityDataId                 String
  activityData                   ActivityData @relation(fields: [activityDataId], references: [id], onDelete: Cascade)
  materialType                   String
  quantityTonnes                 Float
  embeddedEmissionFactorOverride Float?
  sourceLabel                    String?
  createdAt                      DateTime     @default(now())

  @@index([activityDataId])
  @@map("precursor_entries")
}

model EmissionCalculationResult {
  id             String       @id @default(cuid())
  activityDataId String       @unique
  activityData   ActivityData @relation(fields: [activityDataId], references: [id], onDelete: Cascade)

  directCombustionCo2eAr5 Float
  directCombustionCo2eAr4 Float
  directProcessCo2e       Float
  directPrecursorCo2e     Float

  // PFC (aluminium) and process N2O (fertilizer nitric acid) need dual-GWP
  // treatment like combustion CH4/N2O, so — unlike calcination/feedstock
  // carbon, which are CO2-only and fold into directProcessCo2e — they get
  // their own AR5/AR2-BUR3 columns.
  directPfcCo2eAr5        Float @default(0)
  directPfcCo2eAr4        Float @default(0)
  directN2oProcessCo2eAr5 Float @default(0)
  directN2oProcessCo2eAr4 Float @default(0)

  indirectElectricityCo2e Float
  indirectSteamCo2e       Float

  totalDirectCo2eAr5    Float
  totalDirectCo2eAr4    Float
  totalEmissionsCbamAr5 Float
  totalEmissionsCctsAr4 Float

  specificEmbeddedEmissionsCbam Float
  ghgIntensityCcts              Float

  gridEmissionFactorUsed Float
  breakdown              Json

  calculatedAt DateTime @default(now())

  @@map("emission_calculation_results")
}

// BRSR Core (SEBI HO/CFD/CFD-SEC-2/P/CIR/2023/122) — the 9 mandated ESG
// attributes for one facility's financial year. Attribute 1 (GHG footprint)
// is intentionally NOT stored here as a number — it is derived at report-build
// time from the existing ActivityData / EmissionCalculationResult rows for
// this facility that fall inside the FY (see `brsrCalculation.service.ts`),
// on the CCTS/AR2-BUR3 basis, so there is exactly one place that computes
// emissions. Every field below is a manual disclosure input the calculation
// engine has no other source for.
model BrsrCoreReport {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  facilityId String
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  // Financial year this disclosure covers, e.g. "FY2025-26" — resolved against
  // Company.reportingFyStartMonth to bound the ActivityData rollup window.
  reportingPeriod String

  // Denominator for every "per rupee of turnover" intensity ratio (attributes 1, 2, 3, 4).
  turnoverInr Float?

  // --- Attribute 2: Water footprint (manual entry) ---
  waterWithdrawnKl  Float?
  waterDischargedKl Float?

  // --- Attribute 3: Waste management (manual entry) ---
  wasteGeneratedTonnes Float?
  wasteRecoveredTonnes Float?

  // --- Attribute 4: Energy footprint — renewable/non-renewable SPLIT only;
  // the total itself is reused from existing fuel + electricity ActivityData. ---
  renewableEnergyConsumptionGj    Float?
  nonRenewableEnergyConsumptionGj Float?

  // --- Attribute 5: Employee wellbeing (manual entry) ---
  employeeCountTotal   Int?
  employeeCountFemale  Int?
  wagesPaidMaleInr     Float?
  wagesPaidFemaleInr   Float?
  safetyIncidentsCount Int?

  // --- Attribute 6: Gender diversity (manual entry) ---
  womenInWorkforcePct  Float?
  womenInManagementPct Float?

  // --- Attribute 7: Inclusive development (manual entry) ---
  procurementFromMsmePct Float?

  // --- Attribute 8: Openness of business — concentration risk (manual entry) ---
  purchasesFromTop10SuppliersPct Float?
  salesToTop10CustomersPct       Float?

  // --- Attribute 9: Customer fairness (manual entry) ---
  consumerComplaintsCount       Int?
  consumerComplaintsResolvedPct Float?

  // DRAFT -> SUBMITTED, same lifecycle as ActivityData. "Verified" is not a
  // status value here either, for the same reason it isn't on ActivityData —
  // it's derived from an APPROVED BrsrVerificationRequest, see below.
  status DataEntryStatus @default(DRAFT)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  verificationRequest BrsrVerificationRequest?

  // One BRSR Core disclosure per facility per financial year.
  @@unique([facilityId, reportingPeriod])
  @@index([companyId])
  @@map("brsr_core_reports")
}

// Mirrors VerificationRequest's shape for CBAM/CCTS — kept as its own model rather than
// a polymorphic one so the existing ActivityData verification flow is untouched.
model BrsrVerificationRequest {
  id                  String             @id @default(cuid())
  brsrCoreReportId    String             @unique
  brsrCoreReport      BrsrCoreReport     @relation(fields: [brsrCoreReportId], references: [id], onDelete: Cascade)
  status              VerificationStatus @default(PENDING)
  verifierId          String?
  verifier            User?              @relation("BrsrVerifierAssignments", fields: [verifierId], references: [id])
  verifierOrg         String?
  accreditationNumber String?
  statement           String?
  comments            String?
  submittedAt         DateTime           @default(now())
  decidedAt           DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([verifierId])
  @@map("brsr_verification_requests")
}

model RefreshToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  revokedAt  DateTime?
  replacedBy String?
  userAgent  String?
  ipAddress  String?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

enum LeadTool {
  BORDER
  INDIA
  COMPLY
  // "Notify me" waitlist signups for not-yet-built ESG frameworks on /esg —
  // lightweight (email only, see name/company below), tagged per framework so
  // demand signal is visible per-framework before committing to build order.
  ESG_GRI
  ESG_ISSB
  ESG_CSRD
  ESG_CDP
}

model LeadCapture {
  id          String   @id @default(cuid())
  // Nullable because ESG_* waitlist signups are email-only — the calculator
  // tools (BORDER/INDIA/COMPLY) still always supply both.
  name        String?
  email       String
  company     String?
  phone       String?
  toolUsed    LeadTool
  inputsJson  Json
  resultsJson Json
  followedUp  Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([toolUsed])
  @@index([createdAt])
  @@map("lead_captures")
}
