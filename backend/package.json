{
  "name": "intellocarbon-api",
  "version": "1.0.0",
  "description": "Intellocarbon backend API — Environmental Compliance and Climate Intelligence Platform",
  "main": "dist/server.js",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json && mkdir -p dist/assets && cp src/assets/* dist/assets/",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "@sentry/node": "^10.65.0",
    "@sentry/profiling-node": "^10.65.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "node-cron": "^4.5.0",
    "pdfkit": "^0.19.1",
    "prisma": "^5.20.0",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6",
    "resend": "^6.16.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.16.10",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "eslint": "^10.6.0",
    "tsx": "^4.23.0",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.62.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "allowScripts": {
    "@prisma/client@5.22.0": true,
    "@prisma/engines@5.22.0": true,
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true,
    "prisma@5.22.0": true,
    "@sentry/node-cpu-profiler@2.4.2": true
  }
}
