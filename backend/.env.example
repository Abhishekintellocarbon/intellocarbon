# Server
NODE_ENV=development
PORT=4000
# Used for password-reset/verification email links, and added to the CORS
# allowlist alongside the hardcoded production origins in src/config/cors.ts
# (intellocarbon.com, www.intellocarbon.com, intellocarbon.vercel.app, and
# *.vercel.app previews) — update that file, not just this var, if a new
# production domain is added.
CLIENT_URL=http://localhost:3000

# Database
# Local/dev: a plain Postgres connection string.
# Production (Supabase): use the pooled connection (port 6543, ?pgbouncer=true) here,
# and set DIRECT_URL below to the direct connection (port 5432) for migrations.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/intellocarbon?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/intellocarbon?schema=public"

# JWT
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Password reset
PASSWORD_RESET_TOKEN_EXPIRES_MIN=60

# Cookies
COOKIE_DOMAIN=localhost

# Email (Resend) — leave RESEND_API_KEY blank in dev to log emails to the console
# instead of sending. Get a key at https://resend.com after verifying a sending domain.
RESEND_API_KEY=
RESEND_FROM="Intellocarbon <notifications@intellocarbon.com>"
RESEND_REPLY_TO=abhishek@intellocarbon.com

# Payments (Razorpay) — leave blank in dev to run checkout in simulated "dev bypass"
# mode (subscriptions activate immediately without calling Razorpay). Get keys at
# https://dashboard.razorpay.com. Plan IDs are created in the Razorpay dashboard
# (Subscriptions > Plans) — one recurring plan per paid tier.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_ID_CCTS_COMPLIANCE=
RAZORPAY_PLAN_ID_CBAM_COMPLIANCE=
RAZORPAY_PLAN_ID_CBAM_PLUS_CCTS=
